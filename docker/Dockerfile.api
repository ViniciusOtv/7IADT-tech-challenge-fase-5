FROM python:3.11-slim
WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends libgl1 libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*
COPY pyproject.toml ./
COPY src ./src
RUN pip install --no-cache-dir .
COPY models ./models
ENV STRIDEAI_WEIGHTS=/app/models/best.pt
EXPOSE 8000
CMD ["uvicorn", "strideai.api.main:app", "--host", "0.0.0.0", "--port", "8000"]
